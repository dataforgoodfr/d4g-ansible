# Django
DJANGO_ALLOWED_HOSTS=docs.{{ base_domain }}
DJANGO_SECRET_KEY={{ lookup('env', 'DOCS_DJANGO_SECRET_KEY') }}
DJANGO_SETTINGS_MODULE=impress.settings
DJANGO_CONFIGURATION=Production
DJANGO_CSRF_TRUSTED_ORIGINS=https://docs.{{ base_domain }}

# Database
DB_HOST={{ lookup('env', 'POLETECH_DB_HOST') }}
DB_PORT={{ lookup('env', 'POLETECH_DB_PORT') }}
DB_NAME=docs
DB_USER=docs
DB_PASSWORD={{ lookup('env', 'DOCS_DB_PASSWORD') }}

# Redis
REDIS_URL=redis://d4g-docs_redis:6379/0

# S3 Storage
AWS_S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
AWS_S3_ACCESS_KEY_ID={{ lookup('env', 'DOCS_S3_ACCESS_KEY') }}
AWS_S3_SECRET_ACCESS_KEY={{ lookup('env', 'DOCS_S3_SECRET_KEY') }}
AWS_STORAGE_BUCKET_NAME={{ docs_s3_bucket }}
MEDIA_BASE_URL=https://docs.{{ base_domain }}/media/

# OIDC (Authentik)
OIDC_RP_CLIENT_ID={{ lookup('env', 'DOCS_OIDC_CLIENT_ID') }}
OIDC_RP_CLIENT_SECRET={{ lookup('env', 'DOCS_OIDC_CLIENT_SECRET') }}
OIDC_OP_JWKS_ENDPOINT=https://authentik.{{ base_domain }}/application/o/docs/jwks/
OIDC_OP_AUTHORIZATION_ENDPOINT=https://authentik.{{ base_domain }}/application/o/authorize/
OIDC_OP_TOKEN_ENDPOINT=https://authentik.{{ base_domain }}/application/o/token/
OIDC_OP_USER_ENDPOINT=https://authentik.{{ base_domain }}/application/o/userinfo/
OIDC_OP_LOGOUT_ENDPOINT=https://authentik.{{ base_domain }}/application/o/docs/end-session/
OIDC_RP_SIGN_ALGO=RS256
OIDC_RP_SCOPES=openid email profile
OIDC_CREATE_USER=true

LOGIN_REDIRECT_URL=https://docs.{{ base_domain }}
LOGIN_REDIRECT_URL_FAILURE=https://docs.{{ base_domain }}
LOGOUT_REDIRECT_URL=https://docs.{{ base_domain }}

# Collaboration (y-provider)
COLLABORATION_SERVER_SECRET={{ lookup('env', 'DOCS_COLLABORATION_SECRET') }}
Y_PROVIDER_API_KEY={{ lookup('env', 'DOCS_Y_PROVIDER_API_KEY') }}
Y_PROVIDER_API_BASE_URL=http://d4g-docs_y-provider:4444/api/
COLLABORATION_API_URL=https://docs.{{ base_domain }}/collaboration/api/
COLLABORATION_BACKEND_BASE_URL=https://docs.{{ base_domain }}
COLLABORATION_SERVER_ORIGIN=https://docs.{{ base_domain }}
COLLABORATION_LOGGING=true

# SMTP (Stalwart)
DJANGO_EMAIL_HOST=stalwart.services.dataforgood.fr
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_FROM=noreply@d4g.fr
DJANGO_EMAIL_USE_TLS=true

# Python
PYTHONPATH=/app
