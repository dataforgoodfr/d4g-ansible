#!/bin/bash
set -euo pipefail

FLEXIBLE_IP="{{ flexible_ip }}"
INTERFACE="eno1"

# 1. Add flexible IP as secondary address
if ! ip addr show dev $INTERFACE | grep -q "$FLEXIBLE_IP"; then
    ip addr add ${FLEXIBLE_IP}/32 dev $INTERFACE
fi

# 2. Replace default route to prefer flexible IP as source
GATEWAY=$(ip route show default | awk '{print $3}' | head -1)
ip route replace default via $GATEWAY dev $INTERFACE src $FLEXIBLE_IP

# 3. SNAT all outbound traffic on eno1 to flexible IP
#    Inserted at position 1, before Docker's MASQUERADE rules
if ! iptables -t nat -C POSTROUTING -o $INTERFACE -j SNAT --to-source $FLEXIBLE_IP 2>/dev/null; then
    iptables -t nat -I POSTROUTING 1 -o $INTERFACE -j SNAT --to-source $FLEXIBLE_IP
fi
