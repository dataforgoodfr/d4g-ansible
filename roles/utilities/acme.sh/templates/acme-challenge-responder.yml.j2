services:
  app:
    image: nginx:alpine
    volumes:
      - /opt/acme-webroot:/opt/acme-webroot:ro
      - /opt/acme-challenge-responder/acme-nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - d4g-internal
    deploy:
      mode: replicated
      replicas: 1
      placement:
        constraints:
          - node.role == manager

networks:
  d4g-internal:
    external: true
