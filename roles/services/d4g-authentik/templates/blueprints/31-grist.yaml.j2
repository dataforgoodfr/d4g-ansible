version: 1
metadata:
  name: "Grist"
  labels:
    blueprints.goauthentik.io/description: "OAuth2 provider, application, and staff-only access policy for Grist"

entries:
  # Ensure the "staff" group exists
  - model: authentik_core.group
    id: staff-group
    identifiers:
      name: "staff"
    attrs:
      name: "staff"

  # OAuth2/OIDC Provider
  - model: authentik_providers_oauth2.oauth2provider
    id: grist-provider
    identifiers:
      name: "Grist"
    attrs:
      name: "Grist"
      client_type: "confidential"
      client_id: "{{ lookup('env', 'GRIST_OIDC_CLIENT_ID') }}"
      client_secret: "{{ lookup('env', 'GRIST_OIDC_CLIENT_SECRET') }}"
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      redirect_uris:
        - url: "https://grist.{{ base_domain }}/oauth2/callback"
          matching_mode: "strict"
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, authentik Self-signed Certificate]]
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]

  # Application
  - model: authentik_core.application
    id: grist-application
    identifiers:
      slug: "grist"
    attrs:
      name: "Grist"
      slug: "grist"
      policy_engine_mode: "any"
      provider: !KeyOf grist-provider

  # Staff-only access
  - model: authentik_policies.policybinding
    identifiers:
      target: !KeyOf grist-application
      order: 0
    attrs:
      target: !KeyOf grist-application
      group: !KeyOf staff-group
      order: 0
      enabled: true
      negate: false
      timeout: 300
      failure_result: false
